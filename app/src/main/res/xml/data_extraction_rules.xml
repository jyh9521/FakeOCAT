<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="secure_settings.xml"/>
        <exclude domain="file" path="datastore/"/>
        <exclude domain="database" path="ocat_database.db"/>
        <exclude domain="file" path="ai_response_cache/"/>
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="secure_settings.xml"/>
        <exclude domain="file" path="datastore/"/>
        <exclude domain="database" path="ocat_database.db"/>
        <exclude domain="file" path="ai_response_cache/"/>
    </device-transfer>
</data-extraction-rules>
